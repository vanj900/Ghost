# Runtime logs
*.log

# Ghost's RAM files (never committed — they live and die with the process)
/dev/shm/ghost_*.db
/dev/shm/ghost_*.json
ghost_model_*.json
ghost_memory_*.db

# Named pipe (auto-created on start)
/tmp/ghost.pipe
